+###########################################################################
+# Custom skill tree override (auto-imported after db/<re|pre-re>/skill_tree.yml)
+#
+# HOKAGE = the Kagerou (male, 4211) / Oboro (female, 4212) job, repurposed.
+# Both are already Ninja-lineage (MAPID_KAGEROUOBORO = JOBL_2_1|MAPID_NINJA)
+# and already Inherit: Ninja, so the Ninja jutsu come for free.
+#
+# This override MERGES into the base Kagerou/Oboro entries and:
+#   1. STRIPS every native Kagerou (KO_*/KG_*) and Oboro (KO_*/OB_*) skill by
+#      setting MaxLevel: 0 (the parser removes MaxLevel-0 skills on merge).
+#   2. ADDS the 12 custom HOK_* jutsu.
+# Net tree per job: full Ninja set (inherited) + HOK_* customs. No KO_/KG_/OB_.
+#
+# Applies in BOTH renewal and pre-re (import has no Mode tag). Zeroing a skill
+# that doesn't exist in a given mode's base tree is a harmless no-op.
+###########################################################################
+
+Header:
+  Type: SKILL_TREE_DB
+  Version: 1
+
+Body:
+  #########################################################################
+  # KAGEROU (male) - Hokage
+  #########################################################################
+  - Job: Kagerou
+    Inherit:
+      Ninja: true          # keep full Ninja skill set
+    Tree:
+      # --- strip native Kagerou skills (KO_* / KG_*) ---
+      - { Name: KO_YAMIKUMO,     MaxLevel: 0 }
+      - { Name: KO_RIGHT,        MaxLevel: 0 }
+      - { Name: KO_LEFT,         MaxLevel: 0 }
+      - { Name: KO_JYUMONJIKIRI, MaxLevel: 0 }
+      - { Name: KO_SETSUDAN,     MaxLevel: 0 }
+      - { Name: KO_BAKURETSU,    MaxLevel: 0 }
+      - { Name: KO_HAPPOKUNAI,   MaxLevel: 0 }
+      - { Name: KO_MUCHANAGE,    MaxLevel: 0 }
+      - { Name: KO_HUUMARANKA,   MaxLevel: 0 }
+      - { Name: KO_MAKIBISHI,    MaxLevel: 0 }
+      - { Name: KO_MEIKYOUSISUI, MaxLevel: 0 }
+      - { Name: KO_ZANZOU,       MaxLevel: 0 }
